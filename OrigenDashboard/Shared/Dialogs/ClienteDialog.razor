@inject ClienteService Svc
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>@(Existente is null ? "Nuevo cliente" : "Editar cliente")</TitleContent>
    <DialogContent>
        <div class="form-grid" style="min-width:400px;">
            <div class="form-group form-full">
                <label class="form-label">Nombre completo *</label>
                <input class="form-control" @bind="_nombre" placeholder="Nombre del cliente" />
            </div>
            <div class="form-group">
                <label class="form-label">Teléfono</label>
                <input class="form-control" @bind="_telefono" placeholder="9XX XXX XXX" />
            </div>
            <div class="form-group">
                <label class="form-label">Email</label>
                <input type="email" class="form-control" @bind="_email" placeholder="correo@ejemplo.com" />
            </div>
            <div class="form-group form-full">
                <label class="form-label">Observaciones</label>
                <textarea class="form-control" @bind="_obs"></textarea>
            </div>
        </div>
        @if (_error is not null)
        {
            <div style="background:#fdecea;color:#c0392b;padding:8px 12px;border-radius:6px;font-size:12px;margin-top:10px;">@_error</div>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => MudDialog.Cancel()">Cancelar</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Guardar" Disabled="_saving">
            @(_saving ? "Guardando..." : "Guardar")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public ClienteDto? Existente { get; set; }

    private string _nombre = "";
    private string? _telefono;
    private string? _email;
    private string? _obs;
    private bool _saving;
    private string? _error;

    protected override void OnParametersSet()
    {
        if (Existente is not null)
        {
            _nombre = Existente.Nombre;
            _telefono = Existente.Telefono;
            _email = Existente.Email;
            _obs = Existente.Observaciones;
        }
    }

    private async Task Guardar()
    {
        if (string.IsNullOrWhiteSpace(_nombre)) { _error = "El nombre es requerido."; return; }
        _saving = true; _error = null;

        if (Existente is null)
        {
            var (ok, _, err) = await Svc.CrearAsync(new CrearClienteRequest(_nombre, _telefono, _email, _obs));
            if (ok) { Snackbar.Add("Cliente creado.", Severity.Success); MudDialog.Close(); }
            else { _error = err ?? "Error al crear."; _saving = false; }
        }
        else
        {
            var (ok, err) = await Svc.ActualizarAsync(Existente.Id, new ActualizarClienteRequest(_nombre, _telefono, _email, _obs));
            if (ok) { Snackbar.Add("Cliente actualizado.", Severity.Success); MudDialog.Close(); }
            else { _error = err ?? "Error al actualizar."; _saving = false; }
        }
    }
}

@inject EmpleadoService Svc
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>@(Existente is null ? "Nuevo empleado" : "Editar empleado")</TitleContent>
    <DialogContent>
        <div class="form-grid" style="min-width:440px;">
            <div class="form-group form-full">
                <label class="form-label">Nombre completo *</label>
                <input class="form-control" @bind="_nombre" placeholder="Nombre del empleado" />
            </div>
            <div class="form-group">
                <label class="form-label">Cargo</label>
                <select class="form-control" @bind="_cargo">
                    <option value="">— Seleccionar —</option>
                    <option>Estilista</option>
                    <option>Colorista</option>
                    <option>Manicurista</option>
                    <option>Pedicurista</option>
                    <option>Especialista en keratina</option>
                    <option>Barbero</option>
                    <option>Recepcionista</option>
                    <option>Administrador</option>
                    <option>Asistente</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Comisión (%)</label>
                <input type="number" class="form-control" @bind="_comisionPct" step="0.5" min="0" max="100" />
                <div style="display:flex;gap:4px;margin-top:5px;flex-wrap:wrap;">
                    @foreach (var p in new[] { 0m, 5m, 10m, 15m, 20m })
                    {
                        <button type="button"
                                class="pct-btn @(_comisionPct == p ? "pct-active" : "")"
                                @onclick="() => _comisionPct = p">@p%</button>
                    }
                </div>
            </div>
            <div class="form-group">
                <label class="form-label">Usuario de acceso</label>
                <input class="form-control" @bind="_usuarioLogin" placeholder="Opcional" />
            </div>
            @if (Existente is not null)
            {
                <div class="form-group">
                    <label class="form-label">Estado</label>
                    <select class="form-control" @bind="_activo">
                        <option value="true">Activo</option>
                        <option value="false">Inactivo</option>
                    </select>
                </div>
            }
        </div>
        @if (_error is not null)
        {
            <div style="background:#fdecea;color:#c0392b;padding:8px 12px;border-radius:6px;font-size:12px;margin-top:10px;">@_error</div>
        }
        <style>
            .pct-btn { padding:3px 10px;border-radius:14px;border:1.5px solid #d0d8e8;background:white;font-size:11px;font-weight:600;color:#5a6478;cursor:pointer;transition:all .12s; }
            .pct-btn:hover { border-color:#1b3a60;color:#1b3a60; }
            .pct-btn.pct-active { background:#1b3a60;border-color:#1b3a60;color:white; }
        </style>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => MudDialog.Cancel()">Cancelar</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Guardar" Disabled="_saving">
            @(_saving ? "Guardando..." : "Guardar")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public EmpleadoDto? Existente { get; set; }

    private string _nombre = "";
    private string _cargo = "";
    private decimal _comisionPct = 0;
    private string? _usuarioLogin;
    private bool _activo = true;
    private bool _saving;
    private string? _error;

    protected override void OnParametersSet()
    {
        if (Existente is not null)
        {
            _nombre = Existente.Nombre;
            _cargo = Existente.Cargo;
            _comisionPct = Existente.ComisionPct;
            _usuarioLogin = Existente.UsuarioLogin;
            _activo = Existente.Activo;
        }
    }

    private async Task Guardar()
    {
        if (string.IsNullOrWhiteSpace(_nombre)) { _error = "El nombre es requerido."; return; }
        _saving = true; _error = null;

        if (Existente is null)
        {
            var (ok, _, err) = await Svc.CrearAsync(new CrearEmpleadoRequest(_nombre, _cargo, _comisionPct, _usuarioLogin));
            if (ok) { Snackbar.Add("Empleado creado.", Severity.Success); MudDialog.Close(); }
            else { _error = err ?? "Error."; _saving = false; }
        }
        else
        {
            var (ok, err) = await Svc.ActualizarAsync(Existente.Id, new ActualizarEmpleadoRequest(_nombre, _cargo, _comisionPct, _usuarioLogin, _activo));
            if (ok) { Snackbar.Add("Empleado actualizado.", Severity.Success); MudDialog.Close(); }
            else { _error = err ?? "Error."; _saving = false; }
        }
    }
}

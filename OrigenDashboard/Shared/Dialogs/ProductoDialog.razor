@inject ProductoService Svc
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>@(Existente is null ? "Nuevo producto" : "Editar producto")</TitleContent>
    <DialogContent>
        <div class="form-grid" style="min-width:420px;">
            <div class="form-group form-full">
                <label class="form-label">Nombre *</label>
                <input class="form-control" @bind="_nombre" />
            </div>
            <div class="form-group">
                <label class="form-label">Categoría</label>
                <select class="form-control" @bind="_categoria">
                    <option>Shampoo</option><option>Acondicionador</option>
                    <option>Mascarilla</option><option>Tratamiento</option><option>Otro</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Precio de venta (S/)</label>
                <input type="number" class="form-control" @bind="_precio" step="0.01" min="0" />
            </div>
            <div class="form-group">
                <label class="form-label">@(Existente is null ? "Stock inicial" : "Stock actual")</label>
                <input type="number" class="form-control" @bind="_stock" min="0" />
            </div>
            @if (Existente is not null)
            {
                <div class="form-group">
                    <label class="form-label">Estado</label>
                    <select class="form-control" value="@(_activo ? "true" : "false")"
                            @onchange="SetActivo">
                        <option value="true">Activo</option><option value="false">Inactivo</option>
                    </select>
                </div>
            }
        </div>
        @if (_error is not null) { <div style="background:#fdecea;color:#c0392b;padding:8px 12px;border-radius:6px;font-size:12px;margin-top:10px;">@_error</div> }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => MudDialog.Cancel()">Cancelar</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Guardar" Disabled="_saving">@(_saving ? "Guardando..." : "Guardar")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public ProductoDto? Existente { get; set; }

    private string _nombre = ""; private string _categoria = "Shampoo";
    private decimal _precio = 0; private int _stock = 0; private bool _activo = true;
    private bool _saving; private string? _error;

    private void SetActivo(ChangeEventArgs e) => _activo = e.Value?.ToString() == "true";

    protected override void OnParametersSet()
    {
        if (Existente is null) return;
        _nombre = Existente.Nombre; _categoria = Existente.Categoria;
        _precio = Existente.PrecioVenta; _stock = Existente.Stock; _activo = Existente.Activo;
    }

    private async Task Guardar()
    {
        if (string.IsNullOrWhiteSpace(_nombre)) { _error = "El nombre es requerido."; return; }
        _saving = true; _error = null;
        if (Existente is null)
        {
            var (ok, _, err) = await Svc.CrearAsync(new CrearProductoRequest(_nombre, _categoria, _precio, _stock));
            if (ok) { Snackbar.Add("Producto creado.", Severity.Success); MudDialog.Close(); }
            else { _error = err ?? "Error."; _saving = false; }
        }
        else
        {
            var (ok, err) = await Svc.ActualizarAsync(Existente.Id, new ActualizarProductoRequest(_nombre, _categoria, _precio, _stock, _activo));
            if (ok) { Snackbar.Add("Producto actualizado.", Severity.Success); MudDialog.Close(); }
            else { _error = err ?? "Error."; _saving = false; }
        }
    }
}

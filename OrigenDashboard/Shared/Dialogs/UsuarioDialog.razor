@inject UsuarioService Svc
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>@(Existente is null ? "Nuevo usuario" : "Editar usuario")</TitleContent>
    <DialogContent>
        <div class="form-grid" style="min-width:420px;">
            <div class="form-group form-full">
                <label class="form-label">Nombre completo *</label>
                <input class="form-control" @bind="_nombre" />
            </div>
            <div class="form-group">
                <label class="form-label">Nombre de usuario *</label>
                <input class="form-control" @bind="_usuario" disabled="@(Existente is not null)" />
            </div>
            <div class="form-group">
                <label class="form-label">@(Existente is null ? "Contraseña *" : "Nueva contraseña (dejar vacío para no cambiar)")</label>
                <input type="password" class="form-control" @bind="_password" />
            </div>
            <div class="form-group">
                <label class="form-label">Rol</label>
                <select class="form-control" @bind="_rol">
                    <option value="admin">Administrador</option>
                    <option value="empleado">Empleado</option>
                </select>
            </div>
            @if (Existente is not null)
            {
                <div class="form-group">
                    <label class="form-label">Estado</label>
                    <select class="form-control" @bind="_activo">
                        <option value="true">Activo</option><option value="false">Inactivo</option>
                    </select>
                </div>
            }
        </div>
        @if (_error is not null) { <div style="background:#fdecea;color:#c0392b;padding:8px 12px;border-radius:6px;font-size:12px;margin-top:10px;">@_error</div> }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => MudDialog.Cancel()">Cancelar</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Guardar" Disabled="_saving">@(_saving ? "Guardando..." : "Guardar")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public UsuarioDto? Existente { get; set; }

    private string _nombre = ""; private string _usuario = "";
    private string? _password; private string _rol = "empleado"; private bool _activo = true;
    private bool _saving; private string? _error;

    protected override void OnParametersSet()
    {
        if (Existente is null) return;
        _nombre = Existente.NombreCompleto; _usuario = Existente.NombreUsuario;
        _rol = Existente.Rol; _activo = Existente.Activo;
    }

    private async Task Guardar()
    {
        if (string.IsNullOrWhiteSpace(_nombre)) { _error = "El nombre es requerido."; return; }
        if (Existente is null && string.IsNullOrWhiteSpace(_password)) { _error = "La contraseña es requerida."; return; }
        _saving = true; _error = null;

        if (Existente is null)
        {
            var (ok, _, err) = await Svc.CrearAsync(new CrearUsuarioRequest(_nombre, _usuario, _password!, _rol));
            if (ok) { Snackbar.Add("Usuario creado.", Severity.Success); MudDialog.Close(); }
            else { _error = err ?? "Error."; _saving = false; }
        }
        else
        {
            var (ok, err) = await Svc.ActualizarAsync(Existente.Id, new ActualizarUsuarioRequest(_nombre, _password, _rol, _activo));
            if (ok) { Snackbar.Add("Usuario actualizado.", Severity.Success); MudDialog.Close(); }
            else { _error = err ?? "Error."; _saving = false; }
        }
    }
}

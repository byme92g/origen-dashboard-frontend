@page "/servicios"
@inject ServicioService SvcServicios
@inject ProductoService SvcProductos
@inject PaqueteService SvcPaquetes
@inject MudBlazor.IDialogService Dialog
@inject ISnackbar Snackbar
@inject IConfiguration Config

<PageTitle>Servicios &amp; Productos · Origen</PageTitle>

<MudTabs Elevation="0" Rounded="true">

    @* ── Servicios ── *@
    <MudTabPanel Text="Servicios">
        <div class="card">
            <div class="card-header">
                <div class="card-title">Servicios</div>
                <button class="btn btn-primary btn-sm" @onclick="AbrirCrearServicio">+ Nuevo servicio</button>
            </div>
            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr><th>Nombre</th><th>Categoría</th><th>Precio</th><th>Duración</th><th>Comisión</th><th>Estado</th><th></th></tr>
                    </thead>
                    <tbody>
                        @foreach (var s in _servicios)
                        {
                            <tr class="@(!s.Activo ? "row-inactive" : "")">
                                <td class="fw-bold">@s.Nombre</td>
                                <td>@s.Categoria</td>
                                <td><span class="price-cell">S/ @s.Precio.ToString("N2")</span></td>
                                <td class="text-muted">@s.DuracionMin min</td>
                                <td class="text-muted">@s.ComisionPct%</td>
                                <td><span class="badge @(s.Activo ? "badge-green" : "badge-gray")">@(s.Activo ? "Activo" : "Inactivo")</span></td>
                                <td>
                                    <div class="d-flex gap-8">
                                        <button class="btn btn-outline btn-sm" @onclick="() => AbrirEditarServicio(s)">
                                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                            Editar
                                        </button>
                                        <button class="btn @(s.Activo ? "btn-secondary" : "btn-outline") btn-sm" @onclick="() => ToggleActivoServicio(s)">
                                            @(s.Activo ? "Desactivar" : "Activar")
                                        </button>
                                        <button class="btn btn-danger btn-sm" title="Eliminar" @onclick="() => EliminarServicio(s)">
                                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!_servicios.Any())
                        {
                            <tr><td colspan="7" class="text-center text-muted" style="padding:24px;">Sin servicios registrados</td></tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (_totalServicios > 0)
            {
                <div class="pagination-bar">
                    <button class="btn btn-outline btn-sm" disabled="@(_pagServicios <= 1)" @onclick="() => CambiarPagServicios(_pagServicios - 1)">‹ Anterior</button>
                    <span class="pagination-info">Página @_pagServicios de @_totalPagServicios · @_totalServicios registros</span>
                    <button class="btn btn-outline btn-sm" disabled="@(_pagServicios >= _totalPagServicios)" @onclick="() => CambiarPagServicios(_pagServicios + 1)">Siguiente ›</button>
                </div>
            }
        </div>
    </MudTabPanel>

    @* ── Productos ── *@
    <MudTabPanel Text="Productos">
        <div class="card">
            <div class="card-header">
                <div class="card-title">Productos</div>
                <button class="btn btn-primary btn-sm" @onclick="AbrirCrearProducto">+ Nuevo producto</button>
            </div>
            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr><th>Nombre</th><th>Categoría</th><th>Precio</th><th>Stock</th><th>Estado</th><th></th></tr>
                    </thead>
                    <tbody>
                        @foreach (var p in _productos)
                        {
                            <tr class="@(!p.Activo ? "row-inactive" : "")">
                                <td class="fw-bold">@p.Nombre</td>
                                <td>@p.Categoria</td>
                                <td><span class="price-cell">S/ @p.PrecioVenta.ToString("N2")</span></td>
                                <td><span class="badge @(p.Stock <= 0 ? "badge-red" : p.Stock <= 5 ? "badge-gold" : "badge-green")">@p.Stock unid.</span></td>
                                <td><span class="badge @(p.Activo ? "badge-green" : "badge-gray")">@(p.Activo ? "Activo" : "Inactivo")</span></td>
                                <td>
                                    <div class="d-flex gap-8">
                                        <button class="btn btn-outline btn-sm" @onclick="() => AbrirEditarProducto(p)">
                                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                            Editar
                                        </button>
                                        <button class="btn btn-danger btn-sm" title="Eliminar" @onclick="() => EliminarProducto(p)">
                                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!_productos.Any())
                        {
                            <tr><td colspan="6" class="text-center text-muted" style="padding:24px;">Sin productos</td></tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (_totalProductos > 0)
            {
                <div class="pagination-bar">
                    <button class="btn btn-outline btn-sm" disabled="@(_pagProductos <= 1)" @onclick="() => CambiarPagProductos(_pagProductos - 1)">‹ Anterior</button>
                    <span class="pagination-info">Página @_pagProductos de @_totalPagProductos · @_totalProductos registros</span>
                    <button class="btn btn-outline btn-sm" disabled="@(_pagProductos >= _totalPagProductos)" @onclick="() => CambiarPagProductos(_pagProductos + 1)">Siguiente ›</button>
                </div>
            }
        </div>
    </MudTabPanel>

    @* ── Paquetes ── *@
    <MudTabPanel Text="Paquetes">
        <div class="card">
            <div class="card-header">
                <div class="card-title">Paquetes</div>
                <button class="btn btn-primary btn-sm" @onclick="AbrirCrearPaquete">+ Nuevo paquete</button>
            </div>
            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr><th>Nombre</th><th>Descripción</th><th>Precio</th><th>Descuento</th><th>Incluye</th><th>Estado</th><th></th></tr>
                    </thead>
                    <tbody>
                        @foreach (var p in _paquetes)
                        {
                            <tr class="@(!p.Activo ? "row-inactive" : "")">
                                <td class="fw-bold">@p.Nombre</td>
                                <td class="text-muted">@(p.Descripcion ?? "—")</td>
                                <td><span class="price-cell">S/ @p.Precio.ToString("N2")</span></td>
                                <td>
                                    @if (p.Descuento > 0)
                                    {
                                        <span class="badge badge-green">- S/ @p.Descuento.ToString("N2")</span>
                                    }
                                    else { <span class="text-muted">—</span> }
                                </td>
                                <td>
                                    @foreach (var svc in p.Servicios)
                                    {
                                        <span class="pk-svc-chip">@svc.Servicio.Nombre</span>
                                    }
                                    @foreach (var prod in p.Productos)
                                    {
                                        <span class="pk-svc-chip" style="background:#f0f4e8;color:#3a5a1a;">@prod.Producto.Nombre</span>
                                    }
                                </td>
                                <td><span class="badge @(p.Activo ? "badge-green" : "badge-gray")">@(p.Activo ? "Activo" : "Inactivo")</span></td>
                                <td>
                                    <div class="d-flex gap-8">
                                        <button class="btn btn-outline btn-sm" @onclick="() => AbrirEditarPaquete(p)">
                                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                            Editar
                                        </button>
                                        <button class="btn @(p.Activo ? "btn-secondary" : "btn-outline") btn-sm" @onclick="() => ToggleActivoPaquete(p)">
                                            @(p.Activo ? "Desactivar" : "Activar")
                                        </button>
                                        <button class="btn btn-danger btn-sm" title="Eliminar" @onclick="() => EliminarPaquete(p)">
                                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!_paquetes.Any())
                        {
                            <tr><td colspan="7" class="text-center text-muted" style="padding:24px;">Sin paquetes registrados</td></tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (_totalPaquetes > 0)
            {
                <div class="pagination-bar">
                    <button class="btn btn-outline btn-sm" disabled="@(_pagPaquetes <= 1)" @onclick="() => CambiarPagPaquetes(_pagPaquetes - 1)">‹ Anterior</button>
                    <span class="pagination-info">Página @_pagPaquetes de @_totalPagPaquetes · @_totalPaquetes registros</span>
                    <button class="btn btn-outline btn-sm" disabled="@(_pagPaquetes >= _totalPagPaquetes)" @onclick="() => CambiarPagPaquetes(_pagPaquetes + 1)">Siguiente ›</button>
                </div>
            }
        </div>
    </MudTabPanel>

</MudTabs>

@code {
    private List<ServicioDto> _servicios = [];
    private List<ProductoDto> _productos = [];
    private List<PaqueteDto>  _paquetes  = [];

    private List<ServicioDto> _todosServicios = [];
    private List<ProductoDto> _todosProductos = [];

    private int _pagServicios = 1, _totalServicios = 0, _totalPagServicios = 1;
    private int _pagProductos = 1, _totalProductos = 0, _totalPagProductos = 1;
    private int _pagPaquetes  = 1, _totalPaquetes  = 0, _totalPagPaquetes  = 1;
    private int _psServicios = 15, _psProductos = 15, _psPaquetes = 15;

    protected override async Task OnInitializedAsync()
    {
        _psServicios = Config.GetValue<int>("Pagination:ServiciosTable", 15);
        _psProductos = Config.GetValue<int>("Pagination:ProductosTable", 15);
        _psPaquetes  = Config.GetValue<int>("Pagination:PaquetesTable", 15);
        await Task.WhenAll(CargarServicios(), CargarProductos(), CargarPaquetes(), CargarTodosParaDialogs());
    }

    private async Task CargarTodosParaDialogs()
    {
        var t1 = SvcServicios.ListarAsync();
        var t2 = SvcProductos.ListarAsync();
        await Task.WhenAll(t1, t2);
        _todosServicios = (await t1).data ?? [];
        _todosProductos = (await t2).data ?? [];
    }

    private async Task CargarServicios()
    {
        var (ok, data, _) = await SvcServicios.ListarPaginadoAsync(_pagServicios, _psServicios);
        if (ok && data is not null)
        {
            _totalServicios = data.Total;
            _totalPagServicios = Math.Max(1, (int)Math.Ceiling((double)_totalServicios / _psServicios));
            if (_pagServicios > _totalPagServicios) _pagServicios = _totalPagServicios;
            _servicios = data.Items.ToList();
        }
        else _servicios = [];
    }

    private async Task CargarProductos()
    {
        var (ok, data, _) = await SvcProductos.ListarPaginadoAsync(_pagProductos, _psProductos);
        if (ok && data is not null)
        {
            _totalProductos = data.Total;
            _totalPagProductos = Math.Max(1, (int)Math.Ceiling((double)_totalProductos / _psProductos));
            if (_pagProductos > _totalPagProductos) _pagProductos = _totalPagProductos;
            _productos = data.Items.ToList();
        }
        else _productos = [];
    }

    private async Task CargarPaquetes()
    {
        var (ok, data, _) = await SvcPaquetes.ListarPaginadoAsync(_pagPaquetes, _psPaquetes);
        if (ok && data is not null)
        {
            _totalPaquetes = data.Total;
            _totalPagPaquetes = Math.Max(1, (int)Math.Ceiling((double)_totalPaquetes / _psPaquetes));
            if (_pagPaquetes > _totalPagPaquetes) _pagPaquetes = _totalPagPaquetes;
            _paquetes = data.Items.ToList();
        }
        else _paquetes = [];
    }

    private async Task CambiarPagServicios(int p) { _pagServicios = p; await CargarServicios(); }
    private async Task CambiarPagProductos(int p) { _pagProductos = p; await CargarProductos(); }
    private async Task CambiarPagPaquetes(int p)  { _pagPaquetes  = p; await CargarPaquetes(); }

    // ── Toggle activo/inactivo ──────────────────────────────────────────────

    private async Task ToggleActivoServicio(ServicioDto s)
    {
        var (ok, err) = await SvcServicios.ActualizarAsync(s.Id,
            new ActualizarServicioRequest(s.Nombre, s.Categoria, s.Precio, s.DuracionMin, s.ComisionPct, !s.Activo));
        if (ok)
        {
            Snackbar.Add(s.Activo ? "Servicio desactivado." : "Servicio activado.", Severity.Success);
            await CargarServicios();
            _todosServicios = (await SvcServicios.ListarAsync()).data ?? [];
        }
        else Snackbar.Add(err ?? "Error.", Severity.Error);
    }

    private async Task ToggleActivoPaquete(PaqueteDto p)
    {
        var (ok, err) = await SvcPaquetes.ActualizarAsync(p.Id,
            new ActualizarPaqueteRequest(p.Nombre, p.Descripcion, p.Precio, p.Descuento, !p.Activo,
                p.Servicios.Select(s => s.ServicioId).ToList(),
                p.Productos.Select(pr => pr.ProductoId).ToList(),
                p.ComisionPct));
        if (ok)
        {
            Snackbar.Add(p.Activo ? "Paquete desactivado." : "Paquete activado.", Severity.Success);
            await CargarPaquetes();
        }
        else Snackbar.Add(err ?? "Error.", Severity.Error);
    }

    // ── Crear / Editar / Eliminar ───────────────────────────────────────────

    private async Task AbrirCrearServicio()
    {
        var dlg = await Dialog.ShowAsync<Shared.Dialogs.ServicioDialog>("Nuevo servicio");
        if ((await dlg.Result)?.Canceled == false) { await CargarServicios(); _todosServicios = (await SvcServicios.ListarAsync()).data ?? []; }
    }
    private async Task AbrirEditarServicio(ServicioDto s)
    {
        var p = new DialogParameters<Shared.Dialogs.ServicioDialog> { { x => x.Existente, s } };
        var dlg = await Dialog.ShowAsync<Shared.Dialogs.ServicioDialog>("Editar servicio", p);
        if ((await dlg.Result)?.Canceled == false) { await CargarServicios(); _todosServicios = (await SvcServicios.ListarAsync()).data ?? []; }
    }
    private async Task EliminarServicio(ServicioDto s)
    {
        var par = new DialogParameters<Shared.ConfirmDeleteDialog> { { x => x.ItemName, s.Nombre } };
        var dlg = await Dialog.ShowAsync<Shared.ConfirmDeleteDialog>("Confirmar", par);
        if ((await dlg.Result)?.Canceled == false)
        {
            var (ok, err) = await SvcServicios.EliminarAsync(s.Id);
            if (ok) { Snackbar.Add("Servicio eliminado.", Severity.Success); await CargarServicios(); _todosServicios = (await SvcServicios.ListarAsync()).data ?? []; }
            else Snackbar.Add(err ?? "Error.", Severity.Error);
        }
    }

    private async Task AbrirCrearProducto()
    {
        var dlg = await Dialog.ShowAsync<Shared.Dialogs.ProductoDialog>("Nuevo producto");
        if ((await dlg.Result)?.Canceled == false) { await CargarProductos(); _todosProductos = (await SvcProductos.ListarAsync()).data ?? []; }
    }
    private async Task AbrirEditarProducto(ProductoDto p)
    {
        var par = new DialogParameters<Shared.Dialogs.ProductoDialog> { { x => x.Existente, p } };
        var dlg = await Dialog.ShowAsync<Shared.Dialogs.ProductoDialog>("Editar producto", par);
        if ((await dlg.Result)?.Canceled == false) { await CargarProductos(); _todosProductos = (await SvcProductos.ListarAsync()).data ?? []; }
    }
    private async Task EliminarProducto(ProductoDto p)
    {
        var par = new DialogParameters<Shared.ConfirmDeleteDialog> { { x => x.ItemName, p.Nombre } };
        var dlg = await Dialog.ShowAsync<Shared.ConfirmDeleteDialog>("Confirmar", par);
        if ((await dlg.Result)?.Canceled == false)
        {
            var (ok, err) = await SvcProductos.EliminarAsync(p.Id);
            if (ok) { Snackbar.Add("Producto eliminado.", Severity.Success); await CargarProductos(); _todosProductos = (await SvcProductos.ListarAsync()).data ?? []; }
            else Snackbar.Add(err ?? "Error.", Severity.Error);
        }
    }

    private async Task AbrirCrearPaquete()
    {
        var p = new DialogParameters<Shared.Dialogs.PaqueteDialog>
        {
            { x => x.Servicios, _todosServicios },
            { x => x.Productos, _todosProductos }
        };
        var dlg = await Dialog.ShowAsync<Shared.Dialogs.PaqueteDialog>("Nuevo paquete", p);
        if ((await dlg.Result)?.Canceled == false) await CargarPaquetes();
    }
    private async Task AbrirEditarPaquete(PaqueteDto paq)
    {
        var par = new DialogParameters<Shared.Dialogs.PaqueteDialog>
        {
            { x => x.Existente, paq },
            { x => x.Servicios, _todosServicios },
            { x => x.Productos, _todosProductos }
        };
        var dlg = await Dialog.ShowAsync<Shared.Dialogs.PaqueteDialog>("Editar paquete", par);
        if ((await dlg.Result)?.Canceled == false) await CargarPaquetes();
    }
    private async Task EliminarPaquete(PaqueteDto p)
    {
        var par = new DialogParameters<Shared.ConfirmDeleteDialog> { { x => x.ItemName, p.Nombre } };
        var dlg = await Dialog.ShowAsync<Shared.ConfirmDeleteDialog>("Confirmar", par);
        if ((await dlg.Result)?.Canceled == false)
        {
            var (ok, err) = await SvcPaquetes.EliminarAsync(p.Id);
            if (ok) { Snackbar.Add("Paquete eliminado.", Severity.Success); await CargarPaquetes(); }
            else Snackbar.Add(err ?? "Error.", Severity.Error);
        }
    }
}

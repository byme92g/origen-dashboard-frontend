@page "/login"
@inject AuthService Auth
@inject NavigationManager Nav

<div class="login-page">
    <div class="login-card">
        <div class="login-logo">
            <div class="login-logo-text">Origen</div>
            <div class="login-logo-sub">Sistema Administrativo</div>
        </div>

        <EditForm Model="_form" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />

            <div class="form-group mb-16">
                <label class="form-label">Usuario</label>
                <InputText class="form-control" @bind-Value="_form.Usuario" placeholder="usuario" disabled="@_loading" />
            </div>

            <div class="form-group mb-16">
                <label class="form-label">Contraseña</label>
                <InputText type="password" class="form-control" @bind-Value="_form.Password" placeholder="••••••••" disabled="@_loading" />
            </div>

            @if (_error is not null)
            {
                <div style="background:#fdecea;color:#c0392b;padding:10px 14px;border-radius:6px;font-size:13px;margin-bottom:14px;">
                    @_error
                </div>
            }

            <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:11px;" disabled="@_loading">
                @(_loading ? "Ingresando..." : "Iniciar sesión")
            </button>
        </EditForm>
    </div>
</div>

@code {
    private LoginForm _form = new();
    private bool _loading = false;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        if (await Auth.IsAuthenticatedAsync())
            Nav.NavigateTo("/");
    }

    private async Task HandleLogin()
    {
        _loading = true; _error = null;
        var (ok, error) = await Auth.LoginAsync(_form.Usuario, _form.Password);
        if (ok)
            Nav.NavigateTo("/", forceLoad: true);
        else
        {
            _error = error;
            _loading = false;
        }
    }

    private class LoginForm
    {
        public string Usuario { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }
}

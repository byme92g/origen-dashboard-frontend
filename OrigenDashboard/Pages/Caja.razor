@page "/caja"
@inject IngresoService IngresoSvc
@inject EgresoService EgresoSvc

<PageTitle>Control de Caja · Origen</PageTitle>

<div class="d-flex align-center gap-8 mb-16">
    <div class="form-group" style="flex-direction:row;align-items:center;gap:8px;margin:0;">
        <label class="form-label" style="white-space:nowrap;margin:0;">Desde:</label>
        <input type="date" class="form-control" style="width:150px;" @bind="_desde" />
    </div>
    <div class="form-group" style="flex-direction:row;align-items:center;gap:8px;margin:0;">
        <label class="form-label" style="white-space:nowrap;margin:0;">Hasta:</label>
        <input type="date" class="form-control" style="width:150px;" @bind="_hasta" />
    </div>
    <button class="btn btn-primary btn-sm" @onclick="Cargar">Filtrar</button>
    <button class="btn btn-outline btn-sm" @onclick="FiltrarHoy">Hoy</button>
    <button class="btn btn-outline btn-sm" @onclick="FiltrarMes">Este mes</button>
</div>

<div class="kpi-grid" style="grid-template-columns:repeat(3,1fr);">
    <div class="kpi-card green">
        <div class="kpi-icon">💰</div>
        <div>
            <div class="kpi-label">Total ingresos</div>
            <div class="kpi-value">@Fmt(_totalIngresos)</div>
        </div>
    </div>
    <div class="kpi-card red">
        <div class="kpi-icon">📤</div>
        <div>
            <div class="kpi-label">Total egresos</div>
            <div class="kpi-value">@Fmt(_totalEgresos)</div>
        </div>
    </div>
    <div class="kpi-card @(_neto >= 0 ? "green" : "red")">
        <div class="kpi-icon">📊</div>
        <div>
            <div class="kpi-label">Neto</div>
            <div class="kpi-value">@Fmt(_neto)</div>
        </div>
    </div>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
    <div class="card">
        <div class="card-header"><div class="card-title">Ingresos (@_ingresos.Count)</div></div>
        <div class="table-wrap">
            <table class="data-table">
                <thead><tr><th>Fecha</th><th>Concepto</th><th>Método</th><th class="text-right">Total</th></tr></thead>
                <tbody>
                    @foreach (var i in _ingresos)
                    {
                        <tr>
                            <td class="text-muted">@i.Fecha.ToLocalTime().ToString("dd/MM HH:mm")</td>
                            <td>@(i.Servicio?.Nombre ?? i.Producto?.Nombre ?? i.Paquete?.Nombre ?? i.ConceptoPersonalizado ?? "—")</td>
                            <td><span class="badge badge-navy">@i.MetodoPago</span></td>
                            <td class="text-right fw-bold text-green">@Fmt(i.Monto - i.Descuento)</td>
                        </tr>
                    }
                    @if (!_ingresos.Any()) { <tr><td colspan="4" class="text-center text-muted" style="padding:20px;">Sin ingresos</td></tr> }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card">
        <div class="card-header"><div class="card-title">Egresos (@_egresos.Count)</div></div>
        <div class="table-wrap">
            <table class="data-table">
                <thead><tr><th>Fecha</th><th>Descripción</th><th>Categoría</th><th class="text-right">Monto</th></tr></thead>
                <tbody>
                    @foreach (var e in _egresos)
                    {
                        <tr>
                            <td class="text-muted">@e.Fecha.ToLocalTime().ToString("dd/MM HH:mm")</td>
                            <td>@e.Descripcion</td>
                            <td><span class="badge badge-gold">@e.Categoria</span></td>
                            <td class="text-right fw-bold" style="color:#c0392b;">@Fmt(e.Monto)</td>
                        </tr>
                    }
                    @if (!_egresos.Any()) { <tr><td colspan="4" class="text-center text-muted" style="padding:20px;">Sin egresos</td></tr> }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private List<IngresoDto> _ingresos = [];
    private List<EgresoDto> _egresos = [];
    private DateTime _desde = DateTime.Today;
    private DateTime _hasta = DateTime.Today;

    private decimal _totalIngresos => _ingresos.Sum(i => i.Monto - i.Descuento);
    private decimal _totalEgresos => _egresos.Sum(e => e.Monto);
    private decimal _neto => _totalIngresos - _totalEgresos;

    protected override async Task OnInitializedAsync() => await FiltrarHoy();

    private async Task FiltrarHoy()
    {
        _desde = DateTime.Today;
        _hasta = DateTime.Today;
        await Cargar();
    }
    private async Task FiltrarMes()
    {
        _desde = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
        _hasta = DateTime.Today;
        await Cargar();
    }

    private async Task Cargar()
    {
        var desde = _desde.ToUniversalTime();
        var hasta = _hasta.AddDays(1).AddTicks(-1).ToUniversalTime();
        var t1 = IngresoSvc.ListarAsync(desde, hasta);
        var t2 = EgresoSvc.ListarAsync(desde, hasta);
        await Task.WhenAll(t1, t2);
        _ingresos = (await t1).data ?? [];
        _egresos = (await t2).data ?? [];
    }

    private static string Fmt(decimal v) => $"S/ {v:N2}";
}

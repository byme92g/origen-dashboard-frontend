@page "/reportes"
@inject ReporteService Svc

<PageTitle>Reportes · Origen</PageTitle>

<style>
.rango-btn {
    padding: 6px 16px; border: 1.5px solid #d0d8e8; border-radius: 20px;
    background: white; cursor: pointer; font-size: 12px; font-weight: 600;
    color: #5a6478; transition: all .15s; white-space: nowrap; font-family: inherit;
}
.rango-btn:hover { border-color: #1b3a60; color: #1b3a60; background: #f0f4ff; }
.rango-btn.active { border-color: #1b3a60; background: #1b3a60; color: white; }
.report-toolbar { background: white; border-radius: 8px; box-shadow: 0 2px 8px rgba(27,58,96,.08); padding: 16px 20px; margin-bottom: 20px; }
.report-toolbar-row { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
.report-toolbar-divider { width: 1px; height: 24px; background: #e0e6f0; margin: 0 4px; flex-shrink: 0; }
.report-date-label { font-size: 11px; font-weight: 600; color: #8a97b0; text-transform: uppercase; letter-spacing: .05em; white-space: nowrap; }
.report-date-input { border: 1.5px solid #d0d8e8; border-radius: 6px; padding: 6px 10px; font-size: 13px; color: #1b3a60; outline: none; font-family: inherit; }
.report-date-input:focus { border-color: #1b3a60; }
</style>

<div class="report-toolbar">
    <div class="report-toolbar-row" style="margin-bottom:12px;">
        <span class="report-date-label" style="margin-right:4px;">Período:</span>
        <button class="rango-btn @(_rangoActivo == "Hoy" ? "active" : "")"
                @onclick="@(() => SetRango("Hoy", DateTime.Today, DateTime.Today))">Hoy</button>
        <button class="rango-btn @(_rangoActivo == "Semana" ? "active" : "")"
                @onclick="@(() => SetRango("Semana", DateTime.Today.AddDays(-(int)DateTime.Today.DayOfWeek + 1), DateTime.Today))">Esta semana</button>
        <button class="rango-btn @(_rangoActivo == "Mes" ? "active" : "")"
                @onclick="@(() => SetRango("Mes", new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1), DateTime.Today))">Este mes</button>
        <button class="rango-btn @(_rangoActivo == "MesAnt" ? "active" : "")"
                @onclick="@(() => { var m = DateTime.Today.AddMonths(-1); SetRango("MesAnt", new DateTime(m.Year, m.Month, 1), new DateTime(m.Year, m.Month, DateTime.DaysInMonth(m.Year, m.Month))); })">Mes anterior</button>
        <button class="rango-btn @(_rangoActivo == "Año" ? "active" : "")"
                @onclick="@(() => SetRango("Año", new DateTime(DateTime.Today.Year, 1, 1), DateTime.Today))">Este año</button>
    </div>
    <div class="report-toolbar-row">
        <span class="report-date-label">Desde:</span>
        <input type="date" class="report-date-input" @bind="_desde" />
        <span class="report-date-label" style="margin-left:4px;">Hasta:</span>
        <input type="date" class="report-date-input" @bind="_hasta" />
        <div class="report-toolbar-divider"></div>
        <button class="btn btn-primary btn-sm" @onclick="CargarPersonalizado">Aplicar rango</button>
        @if (_loading) { <span class="text-muted" style="font-size:12px;">Cargando...</span> }
    </div>
</div>

@if (_reporte is not null)
{
    <div class="kpi-grid" style="grid-template-columns:repeat(4,1fr);">
        <div class="kpi-card green">
            <div class="kpi-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="19" x2="12" y2="5"/><polyline points="5 12 12 5 19 12"/></svg>
            </div>
            <div>
                <div class="kpi-label">Total ingresos</div>
                <div class="kpi-value">@Fmt(_reporte.Resumen.TotalIngresos)</div>
            </div>
        </div>
        <div class="kpi-card red">
            <div class="kpi-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
            </div>
            <div>
                <div class="kpi-label">Total egresos</div>
                <div class="kpi-value">@Fmt(_reporte.Resumen.TotalEgresos)</div>
            </div>
        </div>
        <div class="kpi-card @(_reporte.Resumen.UtilidadNeta >= 0 ? "green" : "red")">
            <div class="kpi-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
            </div>
            <div>
                <div class="kpi-label">Utilidad neta</div>
                <div class="kpi-value">@Fmt(_reporte.Resumen.UtilidadNeta)</div>
            </div>
        </div>
        <div class="kpi-card gold">
            <div class="kpi-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
            </div>
            <div>
                <div class="kpi-label">Comisiones</div>
                <div class="kpi-value">@Fmt(_reporte.Resumen.TotalComisiones)</div>
            </div>
        </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
        <div class="card">
            <div class="card-header"><div class="card-title">Top servicios</div></div>
            <div class="table-wrap">
                <table class="data-table">
                    <thead><tr><th>#</th><th>Servicio</th><th>Cantidad</th><th class="text-right">Total</th></tr></thead>
                    <tbody>
                        @{ var i = 1; }
                        @foreach (var s in _reporte.TopServicios)
                        {
                            <tr>
                                <td class="text-muted">@(i++)</td>
                                <td class="fw-bold">@s.Servicio</td>
                                <td>@s.Cantidad</td>
                                <td class="text-right">@Fmt(s.Total)</td>
                            </tr>
                        }
                        @if (!_reporte.TopServicios.Any()) { <tr><td colspan="4" class="text-center text-muted" style="padding:20px;">Sin datos</td></tr> }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card">
            <div class="card-header"><div class="card-title">Por empleado</div></div>
            <div class="table-wrap">
                <table class="data-table">
                    <thead><tr><th>Empleado</th><th>Servicios</th><th>Ventas</th><th class="text-right">Comisión</th></tr></thead>
                    <tbody>
                        @foreach (var e in _reporte.PorEmpleado)
                        {
                            <tr>
                                <td class="fw-bold">@e.Empleado</td>
                                <td>@e.Servicios</td>
                                <td>@Fmt(e.TotalVentas)</td>
                                <td class="text-right badge-gold">@Fmt(e.TotalComision)</td>
                            </tr>
                        }
                        @if (!_reporte.PorEmpleado.Any()) { <tr><td colspan="4" class="text-center text-muted" style="padding:20px;">Sin datos</td></tr> }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card">
            <div class="card-header"><div class="card-title">Por método de pago</div></div>
            <div class="card-body">
                @foreach (var m in _reporte.PorMetodoPago)
                {
                    var pct = _reporte.Resumen.TotalIngresos > 0 ? (int)((m.Total / _reporte.Resumen.TotalIngresos) * 100) : 0;
                    <div style="margin-bottom:12px;">
                        <div class="d-flex justify-between align-center" style="margin-bottom:4px;">
                            <span style="font-size:13px;font-weight:500;text-transform:capitalize;">@m.Metodo</span>
                            <span class="fw-bold" style="font-size:13px;">@Fmt(m.Total) <span class="text-muted">(@pct%)</span></span>
                        </div>
                        <div style="background:#eef1f6;border-radius:4px;height:6px;">
                            <div style="background:var(--navy);height:6px;border-radius:4px;width:@(pct)%;"></div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    private DateTime _desde = new(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime _hasta = DateTime.Today;
    private string _rangoActivo = "Mes";
    private ResumenReporte? _reporte;
    private bool _loading = false;

    protected override async Task OnInitializedAsync() => await Cargar();

    private async Task Cargar()
    {
        _loading = true;
        var (ok, data, _) = await Svc.ObtenerResumenAsync(_desde.ToUniversalTime(), _hasta.AddDays(1).AddTicks(-1).ToUniversalTime());
        if (ok) _reporte = data;
        _loading = false;
    }

    private async Task SetRango(string label, DateTime desde, DateTime hasta)
    {
        _rangoActivo = label;
        _desde = desde;
        _hasta = hasta;
        await Cargar();
    }

    private async Task CargarPersonalizado()
    {
        _rangoActivo = "";
        await Cargar();
    }

    private static string Fmt(decimal v) => $"S/ {v:N2}";
}

@page "/empleados"
@inject EmpleadoService Svc
@inject UsuarioService UsuarioSvc
@inject MudBlazor.IDialogService Dialog
@inject ISnackbar Snackbar
@inject IConfiguration Config

<PageTitle>Personal · Origen</PageTitle>

<MudTabs Elevation="0" Rounded="true">

    @* ── Empleados ── *@
    <MudTabPanel Text="Empleados">
        <div class="card">
            <div class="card-header">
                <div class="card-title">Empleados</div>
                <button class="btn btn-primary btn-sm" @onclick="AbrirCrearEmpleado">+ Nuevo empleado</button>
            </div>
            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr><th>Nombre</th><th>Cargo</th><th>Comisión</th><th>Cuenta de acceso</th><th>Estado</th><th></th></tr>
                    </thead>
                    <tbody>
                        @if (_loadingEmp)
                        {
                            <tr><td colspan="6" class="text-center text-muted" style="padding:24px;">Cargando...</td></tr>
                        }
                        else
                        {
                            @foreach (var e in _empleados)
                            {
                                <tr>
                                    <td class="fw-bold">@e.Nombre</td>
                                    <td>@e.Cargo</td>
                                    <td class="text-muted">@e.ComisionPct%</td>
                                    <td class="text-muted">@(e.UsuarioLogin ?? "—")</td>
                                    <td>
                                        <span class="badge @(e.Activo ? "badge-green" : "badge-gray")">
                                            @(e.Activo ? "Activo" : "Inactivo")
                                        </span>
                                    </td>
                                    <td>
                                        <div class="d-flex gap-8">
                                            <button class="btn btn-outline btn-sm" @onclick="() => AbrirEditarEmpleado(e)">
                                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                                Editar
                                            </button>
                                            <button class="btn btn-danger btn-sm" title="Eliminar" @onclick="() => EliminarEmpleado(e)">
                                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                            @if (!_empleados.Any())
                            {
                                <tr><td colspan="6" class="text-center text-muted" style="padding:24px;">Sin empleados registrados</td></tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            @if (_totalEmp > 0)
            {
                <div class="pagination-bar">
                    <button class="btn btn-outline btn-sm" disabled="@(_pagEmp <= 1)" @onclick="() => CambiarPagEmp(_pagEmp - 1)">‹ Anterior</button>
                    <span class="pagination-info">Página @_pagEmp de @_totalPagEmp · @_totalEmp registros</span>
                    <button class="btn btn-outline btn-sm" disabled="@(_pagEmp >= _totalPagEmp)" @onclick="() => CambiarPagEmp(_pagEmp + 1)">Siguiente ›</button>
                </div>
            }
        </div>
    </MudTabPanel>

    @* ── Usuarios del sistema ── *@
    <MudTabPanel Text="Usuarios del sistema">
        <div class="card">
            <div class="card-header">
                <div class="card-title">Usuarios del sistema</div>
                <button class="btn btn-primary btn-sm" @onclick="AbrirCrearUsuario">+ Nuevo usuario</button>
            </div>
            <div class="table-wrap">
                <table class="data-table">
                    <thead><tr><th>Usuario</th><th>Nombre completo</th><th>Rol</th><th>Estado</th><th></th></tr></thead>
                    <tbody>
                        @if (_loadingUsr)
                        {
                            <tr><td colspan="5" class="text-center text-muted" style="padding:24px;">Cargando...</td></tr>
                        }
                        else
                        {
                            @foreach (var u in _usuarios)
                            {
                                <tr>
                                    <td class="fw-bold">@u.NombreUsuario</td>
                                    <td>@u.NombreCompleto</td>
                                    <td><span class="badge @(u.Rol == "admin" ? "badge-navy" : "badge-gold")">@u.Rol</span></td>
                                    <td><span class="badge @(u.Activo ? "badge-green" : "badge-gray")">@(u.Activo ? "Activo" : "Inactivo")</span></td>
                                    <td>
                                        <div class="d-flex gap-8">
                                            <button class="btn btn-outline btn-sm" @onclick="() => AbrirEditarUsuario(u)">
                                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                                Editar
                                            </button>
                                            <button class="btn btn-danger btn-sm" title="Eliminar" @onclick="() => EliminarUsuario(u)">
                                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                            @if (!_usuarios.Any()) { <tr><td colspan="5" class="text-center text-muted" style="padding:24px;">Sin usuarios</td></tr> }
                        }
                    </tbody>
                </table>
            </div>
            @if (_totalUsr > 0)
            {
                <div class="pagination-bar">
                    <button class="btn btn-outline btn-sm" disabled="@(_pagUsr <= 1)" @onclick="() => CambiarPagUsr(_pagUsr - 1)">‹ Anterior</button>
                    <span class="pagination-info">Página @_pagUsr de @_totalPagUsr · @_totalUsr registros</span>
                    <button class="btn btn-outline btn-sm" disabled="@(_pagUsr >= _totalPagUsr)" @onclick="() => CambiarPagUsr(_pagUsr + 1)">Siguiente ›</button>
                </div>
            }
        </div>
    </MudTabPanel>

</MudTabs>

@code {
    // ── Empleados ──────────────────────────────────────────────────────────
    private List<EmpleadoDto> _empleados = [];
    private bool _loadingEmp = true;
    private int _pagEmp = 1, _totalEmp = 0, _totalPagEmp = 1, _psSizeEmp = 15;

    // ── Usuarios ──────────────────────────────────────────────────────────
    private List<UsuarioDto> _usuarios = [];
    private bool _loadingUsr = true;
    private int _pagUsr = 1, _totalUsr = 0, _totalPagUsr = 1, _psSizeUsr = 15;

    protected override async Task OnInitializedAsync()
    {
        _psSizeEmp = Config.GetValue<int>("Pagination:EmpleadosTable", 15);
        _psSizeUsr = Config.GetValue<int>("Pagination:UsuariosTable", 15);
        await Task.WhenAll(CargarEmpleados(), CargarUsuarios());
    }

    // ── Carga ──────────────────────────────────────────────────────────────

    private async Task CargarEmpleados()
    {
        _loadingEmp = true;
        var (ok, data, _) = await Svc.ListarPaginadoAsync(_pagEmp, _psSizeEmp);
        if (ok && data is not null)
        {
            _totalEmp = data.Total;
            _totalPagEmp = Math.Max(1, (int)Math.Ceiling((double)_totalEmp / _psSizeEmp));
            if (_pagEmp > _totalPagEmp) _pagEmp = _totalPagEmp;
            _empleados = data.Items.ToList();
        }
        else _empleados = [];
        _loadingEmp = false;
    }

    private async Task CargarUsuarios()
    {
        _loadingUsr = true;
        var (ok, data, _) = await UsuarioSvc.ListarPaginadoAsync(_pagUsr, _psSizeUsr);
        if (ok && data is not null)
        {
            _totalUsr = data.Total;
            _totalPagUsr = Math.Max(1, (int)Math.Ceiling((double)_totalUsr / _psSizeUsr));
            if (_pagUsr > _totalPagUsr) _pagUsr = _totalPagUsr;
            _usuarios = data.Items.ToList();
        }
        else _usuarios = [];
        _loadingUsr = false;
    }

    private async Task CambiarPagEmp(int p) { _pagEmp = p; await CargarEmpleados(); }
    private async Task CambiarPagUsr(int p) { _pagUsr = p; await CargarUsuarios(); }

    // ── CRUD Empleados ─────────────────────────────────────────────────────

    private async Task AbrirCrearEmpleado()
    {
        var dlg = await Dialog.ShowAsync<Shared.Dialogs.EmpleadoDialog>("Nuevo empleado");
        if ((await dlg.Result)?.Canceled == false) await CargarEmpleados();
    }

    private async Task AbrirEditarEmpleado(EmpleadoDto e)
    {
        var p = new DialogParameters<Shared.Dialogs.EmpleadoDialog> { { x => x.Existente, e } };
        var dlg = await Dialog.ShowAsync<Shared.Dialogs.EmpleadoDialog>("Editar empleado", p);
        if ((await dlg.Result)?.Canceled == false) await CargarEmpleados();
    }

    private async Task EliminarEmpleado(EmpleadoDto e)
    {
        var par = new DialogParameters<Shared.ConfirmDeleteDialog> { { x => x.ItemName, e.Nombre } };
        var dlg = await Dialog.ShowAsync<Shared.ConfirmDeleteDialog>("Confirmar", par);
        if ((await dlg.Result)?.Canceled == false)
        {
            var (ok, err) = await Svc.EliminarAsync(e.Id);
            if (ok) { Snackbar.Add("Empleado eliminado.", Severity.Success); await CargarEmpleados(); }
            else Snackbar.Add(err ?? "Error al eliminar.", Severity.Error);
        }
    }

    // ── CRUD Usuarios ──────────────────────────────────────────────────────

    private async Task AbrirCrearUsuario()
    {
        var dlg = await Dialog.ShowAsync<Shared.Dialogs.UsuarioDialog>("Nuevo usuario");
        if ((await dlg.Result)?.Canceled == false) await CargarUsuarios();
    }

    private async Task AbrirEditarUsuario(UsuarioDto u)
    {
        var p = new DialogParameters<Shared.Dialogs.UsuarioDialog> { { x => x.Existente, u } };
        var dlg = await Dialog.ShowAsync<Shared.Dialogs.UsuarioDialog>("Editar usuario", p);
        if ((await dlg.Result)?.Canceled == false) await CargarUsuarios();
    }

    private async Task EliminarUsuario(UsuarioDto u)
    {
        var par = new DialogParameters<Shared.ConfirmDeleteDialog> { { x => x.ItemName, u.NombreUsuario } };
        var dlg = await Dialog.ShowAsync<Shared.ConfirmDeleteDialog>("Confirmar", par);
        if ((await dlg.Result)?.Canceled == false)
        {
            var (ok, err) = await UsuarioSvc.EliminarAsync(u.Id);
            if (ok) { Snackbar.Add("Usuario eliminado.", Severity.Success); await CargarUsuarios(); }
            else Snackbar.Add(err ?? "Error al eliminar.", Severity.Error);
        }
    }
}

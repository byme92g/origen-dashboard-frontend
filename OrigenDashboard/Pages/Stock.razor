@page "/stock"
@inject ProductoService SvcProductos
@inject MudBlazor.IDialogService Dialog
@inject ISnackbar Snackbar

<PageTitle>Control de Stock · Origen</PageTitle>

@if (_loading)
{
    <div class="text-center text-muted" style="padding:40px;">Cargando inventario...</div>
}
else
{
    @* ── Resumen de alertas ── *@
    @if (_sinStock.Any() || _stockBajo.Any())
    {
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:20px;">
            @if (_sinStock.Any())
            {
                <div class="kpi-card red">
                    <div class="kpi-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    </div>
                    <div>
                        <div class="kpi-label">Sin stock</div>
                        <div class="kpi-value" style="font-size:1.4rem;">@_sinStock.Count productos</div>
                    </div>
                </div>
            }
            @if (_stockBajo.Any())
            {
                <div class="kpi-card gold">
                    <div class="kpi-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                    </div>
                    <div>
                        <div class="kpi-label">Stock bajo (≤ 5 unid.)</div>
                        <div class="kpi-value" style="font-size:1.4rem;">@_stockBajo.Count productos</div>
                    </div>
                </div>
            }
        </div>
    }

    @* ── Filtros ── *@
    <div class="card">
        <div class="card-header">
            <div class="card-title">Inventario de productos</div>
            <div class="d-flex gap-8">
                <button class="btn @(_filtro == "todos" ? "btn-primary" : "btn-outline") btn-sm" @onclick='() => _filtro = "todos"'>Todos</button>
                <button class="btn @(_filtro == "bajo" ? "btn-primary" : "btn-outline") btn-sm" @onclick='() => _filtro = "bajo"'>
                    Stock bajo
                    @if (_stockBajo.Any()) { <span class="badge badge-gold" style="margin-left:4px;">@_stockBajo.Count</span> }
                </button>
                <button class="btn @(_filtro == "sin" ? "btn-primary" : "btn-outline") btn-sm" @onclick='() => _filtro = "sin"'>
                    Sin stock
                    @if (_sinStock.Any()) { <span class="badge badge-red" style="margin-left:4px;">@_sinStock.Count</span> }
                </button>
            </div>
        </div>
        <div class="table-wrap">
            <table class="data-table">
                <thead>
                    <tr><th>Producto</th><th>Categoría</th><th>Precio venta</th><th>Stock actual</th><th>Estado</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var p in ProductosFiltrados)
                    {
                        <tr style="@(p.Stock <= 0 ? "background:#fff8f7;" : p.Stock <= 5 ? "background:#fffdf0;" : "")">
                            <td class="fw-bold">@p.Nombre</td>
                            <td>@p.Categoria</td>
                            <td><span class="price-cell">S/ @p.PrecioVenta.ToString("N2")</span></td>
                            <td>
                                <span class="badge @(p.Stock <= 0 ? "badge-red" : p.Stock <= 5 ? "badge-gold" : "badge-green")">
                                    @p.Stock unid.
                                </span>
                                @if (p.Stock <= 0)
                                {
                                    <span style="font-size:11px;color:#c0392b;margin-left:6px;font-weight:500;">Sin stock</span>
                                }
                                else if (p.Stock <= 5)
                                {
                                    <span style="font-size:11px;color:var(--gold);margin-left:6px;font-weight:500;">Stock bajo</span>
                                }
                            </td>
                            <td><span class="badge @(p.Activo ? "badge-green" : "badge-gray")">@(p.Activo ? "Activo" : "Inactivo")</span></td>
                            <td>
                                <button class="btn btn-outline btn-sm" @onclick="() => AjustarStock(p)">
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                    Ajustar
                                </button>
                            </td>
                        </tr>
                    }
                    @if (!ProductosFiltrados.Any())
                    {
                        <tr><td colspan="6" class="text-center text-muted" style="padding:24px;">Sin productos en esta categoría</td></tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="pagination-bar" style="border-top:1px solid #f0f4f8;padding:10px 16px;">
            <span class="pagination-info" style="text-align:left;">@ProductosFiltrados.Count() de @_todos.Count productos</span>
        </div>
    </div>
}

@code {
    private List<ProductoDto> _todos = [];
    private bool _loading = true;
    private string _filtro = "todos";

    private List<ProductoDto> _sinStock => _todos.Where(p => p.Stock <= 0).ToList();
    private List<ProductoDto> _stockBajo => _todos.Where(p => p.Stock > 0 && p.Stock <= 5).ToList();

    private IEnumerable<ProductoDto> ProductosFiltrados => _filtro switch
    {
        "sin"  => _todos.Where(p => p.Stock <= 0),
        "bajo" => _todos.Where(p => p.Stock <= 5),
        _      => _todos.OrderBy(p => p.Stock)
    };

    protected override async Task OnInitializedAsync() => await Cargar();

    private async Task Cargar()
    {
        _loading = true;
        var (ok, data, _) = await SvcProductos.ListarAsync();
        _todos = ok && data is not null ? data : [];
        _loading = false;
    }

    private async Task AjustarStock(ProductoDto p)
    {
        var par = new DialogParameters<Shared.Dialogs.ProductoDialog> { { x => x.Existente, p } };
        var dlg = await Dialog.ShowAsync<Shared.Dialogs.ProductoDialog>("Ajustar producto", par);
        if ((await dlg.Result)?.Canceled == false) await Cargar();
    }
}

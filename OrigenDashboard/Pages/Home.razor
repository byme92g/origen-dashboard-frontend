@page "/"
@inject ReporteService ReportesSvc

<PageTitle>Dashboard · Origen</PageTitle>

<div class="quick-actions">
    <a href="/ingresos" class="quick-action qa-primary">
        <div class="qa-icon">💰</div>
        <div class="qa-label">Registrar Ingreso</div>
    </a>
    <a href="/egresos" class="quick-action qa-red">
        <div class="qa-icon">📤</div>
        <div class="qa-label">Registrar Egreso</div>
    </a>
    <a href="/caja" class="quick-action">
        <div class="qa-icon">🏦</div>
        <div class="qa-label">Control de Caja</div>
    </a>
    <a href="/clientes" class="quick-action">
        <div class="qa-icon">👤</div>
        <div class="qa-label">Clientes</div>
    </a>
    <a href="/servicios" class="quick-action">
        <div class="qa-icon">✂️</div>
        <div class="qa-label">Servicios</div>
    </a>
    <a href="/reportes" class="quick-action">
        <div class="qa-icon">📈</div>
        <div class="qa-label">Reportes</div>
    </a>
</div>

@if (_loading)
{
    <div class="text-center text-muted" style="padding:40px;">Cargando dashboard...</div>
}
else if (_data is not null)
{
    <div class="kpi-grid">
        <div class="kpi-card gold">
            <div class="kpi-icon">💰</div>
            <div>
                <div class="kpi-label">Ingresos hoy</div>
                <div class="kpi-value">@Fmt(_data.Kpis.IngresosHoy)</div>
            </div>
        </div>
        <div class="kpi-card red">
            <div class="kpi-icon">📤</div>
            <div>
                <div class="kpi-label">Egresos mes</div>
                <div class="kpi-value">@Fmt(_data.Kpis.EgresosMes)</div>
            </div>
        </div>
        <div class="kpi-card green">
            <div class="kpi-icon">📈</div>
            <div>
                <div class="kpi-label">Utilidad mes</div>
                <div class="kpi-value">@Fmt(_data.Kpis.UtilidadMes)</div>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon">👥</div>
            <div>
                <div class="kpi-label">Clientes totales</div>
                <div class="kpi-value">@_data.Kpis.TotalClientes</div>
            </div>
        </div>
        <div class="kpi-card amber">
            <div class="kpi-icon">✂️</div>
            <div>
                <div class="kpi-label">Servicios hoy</div>
                <div class="kpi-value">@_data.Kpis.ServiciosHoy</div>
            </div>
        </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
        <div class="card">
            <div class="card-header">
                <div class="card-title">Últimas transacciones hoy</div>
            </div>
            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr><th>Cliente</th><th>Concepto</th><th>Método</th><th class="text-right">Total</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var t in _data.UltimasTransacciones)
                        {
                            <tr>
                                <td>@t.Cliente</td>
                                <td>@t.Concepto</td>
                                <td><span class="badge badge-navy">@t.MetodoPago</span></td>
                                <td class="text-right fw-bold">@Fmt(t.Monto - t.Descuento)</td>
                            </tr>
                        }
                        @if (!_data.UltimasTransacciones.Any())
                        {
                            <tr><td colspan="4" class="text-center text-muted" style="padding:20px;">Sin transacciones hoy</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card">
            <div class="card-header"><div class="card-title">Ingresos hoy por método</div></div>
            <div class="card-body">
                @foreach (var m in _data.PorMetodoPago)
                {
                    var pct = _data.Kpis.IngresosHoy > 0 ? (int)((m.Total / _data.Kpis.IngresosHoy) * 100) : 0;
                    <div style="margin-bottom:14px;">
                        <div class="d-flex justify-between align-center" style="margin-bottom:4px;">
                            <span style="font-size:13px;font-weight:500;text-transform:capitalize;">@m.Metodo</span>
                            <span class="fw-bold" style="font-size:13px;">@Fmt(m.Total) <span class="text-muted">(@pct%)</span></span>
                        </div>
                        <div style="background:#eef1f6;border-radius:4px;height:6px;">
                            <div style="background:var(--navy);height:6px;border-radius:4px;width:@(pct)%;transition:width .3s;"></div>
                        </div>
                    </div>
                }
                @if (!_data.PorMetodoPago.Any())
                {
                    <div class="text-center text-muted">Sin datos hoy</div>
                }
            </div>
        </div>
    </div>
}
else
{
    <div class="text-center text-muted" style="padding:40px;">No se pudieron cargar los datos.</div>
}

@code {
    private DashboardData? _data;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        var (ok, data, _) = await ReportesSvc.ObtenerDashboardAsync();
        if (ok) _data = data;
        _loading = false;
    }

    private static string Fmt(decimal v) => $"S/ {v:N2}";
}

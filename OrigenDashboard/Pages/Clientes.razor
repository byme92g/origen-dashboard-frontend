@page "/clientes"
@inject ClienteService Svc
@inject MudBlazor.IDialogService Dialog
@inject ISnackbar Snackbar
@inject IConfiguration Config

<PageTitle>Clientes · Origen</PageTitle>

<div class="card">
    <div class="card-header">
        <div class="card-title">Clientes</div>
        <button class="btn btn-primary btn-sm" @onclick="AbrirCrear">+ Nuevo cliente</button>
    </div>
    <div class="table-wrap">
        <table class="data-table">
            <thead>
                <tr><th>Nombre</th><th>Teléfono</th><th>Email</th><th>Observaciones</th><th>Registro</th><th></th></tr>
            </thead>
            <tbody>
                @if (_loading)
                {
                    <tr><td colspan="6" class="text-center text-muted" style="padding:24px;">Cargando...</td></tr>
                }
                else
                {
                    @foreach (var c in _clientes)
                    {
                        <tr>
                            <td class="fw-bold">@c.Nombre</td>
                            <td>@(c.Telefono ?? "—")</td>
                            <td>@(c.Email ?? "—")</td>
                            <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@(c.Observaciones ?? "—")</td>
                            <td class="text-muted">@c.FechaRegistro.ToLocalTime().ToString("dd/MM/yyyy")</td>
                            <td>
                                <div class="d-flex gap-8">
                                    <button class="btn btn-outline btn-sm" @onclick="() => AbrirEditar(c)">
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                    </button>
                                    <button class="btn btn-danger btn-sm" title="Eliminar" @onclick="() => Eliminar(c)">
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!_clientes.Any())
                    {
                        <tr><td colspan="6" class="text-center text-muted" style="padding:24px;">Sin clientes registrados</td></tr>
                    }
                }
            </tbody>
        </table>
    </div>
    @if (_total > 0)
    {
        <div class="pagination-bar">
            <button class="btn btn-outline btn-sm" disabled="@(_pagina <= 1)" @onclick="() => CambiarPagina(_pagina - 1)">‹ Anterior</button>
            <span class="pagination-info">Página @_pagina de @_totalPaginas · @_total registros</span>
            <button class="btn btn-outline btn-sm" disabled="@(_pagina >= _totalPaginas)" @onclick="() => CambiarPagina(_pagina + 1)">Siguiente ›</button>
        </div>
    }
</div>

@code {
    private List<ClienteDto> _clientes = [];
    private bool _loading = true;
    private int _pagina = 1;
    private int _total = 0;
    private int _totalPaginas = 1;
    private int _pageSize = 15;

    protected override async Task OnInitializedAsync()
    {
        _pageSize = Config.GetValue<int>("Pagination:ClientesTable", 15);
        await Cargar();
    }

    private async Task Cargar()
    {
        _loading = true;
        var (ok, data, _) = await Svc.ListarPaginadoAsync(_pagina, _pageSize);
        if (ok && data is not null)
        {
            _total = data.Total;
            _totalPaginas = Math.Max(1, (int)Math.Ceiling((double)_total / _pageSize));
            if (_pagina > _totalPaginas) _pagina = _totalPaginas;
            _clientes = data.Items.ToList();
        }
        else _clientes = [];
        _loading = false;
    }

    private async Task CambiarPagina(int pagina) { _pagina = pagina; await Cargar(); }

    private async Task AbrirCrear()
    {
        var dlg = await Dialog.ShowAsync<Shared.Dialogs.ClienteDialog>("Nuevo cliente");
        var res = await dlg.Result;
        if (res?.Canceled == false) await Cargar();
    }

    private async Task AbrirEditar(ClienteDto c)
    {
        var params_ = new DialogParameters<Shared.Dialogs.ClienteDialog> { { x => x.Existente, c } };
        var dlg = await Dialog.ShowAsync<Shared.Dialogs.ClienteDialog>("Editar cliente", params_);
        var res = await dlg.Result;
        if (res?.Canceled == false) await Cargar();
    }

    private async Task Eliminar(ClienteDto c)
    {
        var parameters = new DialogParameters();
        parameters.Add("ItemName", c.Nombre);
        var dialog = await Dialog.ShowAsync<ConfirmDeleteDialog>("Confirmar", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            var (success, error) = await Svc.EliminarAsync(c.Id);
            if (success) 
            { 
                Snackbar.Add("Cliente eliminado.", Severity.Success); 
                await Cargar(); 
            }
            else 
                Snackbar.Add(error ?? "Error al eliminar.", Severity.Error);
        }
    }
}
